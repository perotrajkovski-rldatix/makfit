{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "android:prepare:release": "npm run build && npm run cap:sync:android",
    "android:bundle:release": "npm run android:prepare:release && cd android && gradlew.bat bundleRelease",
    "android:bundle:release:clean": "npm run android:prepare:release && cd android && gradlew.bat clean bundleRelease"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
